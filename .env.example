# Copy to .env and adjust values.
# Existing shell env vars have priority over this file.

# Reproducibility
EXPERIMENT_SEED=17

# Base training
TRAIN_SAMPLES_PER_CLASS=2000
TRAIN_FLIP_PROBABILITY=0.05
TRAIN_MAX_SHIFT=1
TRAIN_EPOCHS=1000
MLP_HIDDEN_DIM=12
MLP_LEARNING_RATE=0.08
VERBOSE_TRAINING=true

# Additional hardening/fine-tuning rounds (for stronger robustness)
EXTRA_TRAINING_ROUNDS=0
EXTRA_SAMPLES_PER_CLASS=1000
EXTRA_FLIP_PROBABILITY=0.12
EXTRA_MAX_SHIFT=1
EXTRA_EPOCHS_PER_ROUND=250

# Evaluation size
EVAL_SAMPLES_PER_CLASS=250
EVAL_SEQUENCE_COUNT=500

# Fixed-point export
FRACTIONAL_BITS=8
